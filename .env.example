# Environment variables needed for dyad local development.
# To use, copy this file to a new file named ".env" and fill in your private keys and settings.
# Your actual .env file should NOT be committed.

# AI Provider API Keys(Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=


# Local AI Model Configuration (Optional)
# Set these if you are running local AI models like Ollama or LM Studio.
# Default for Ollama is http://127.0.0.1:11434
OLLAMA_HOST=

# GitHub Integration (Optional)
# Needed for features that interact with GitHub repositories.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=


# Apple Notarization (macOS Build Only)
# Only required if you are building and signing a release version for macOS.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
SM_CODE_SIGNING_CERT_SHA1=


# ── Web Server ────────────────────────────────────────────────────────────────
# Used when running npm run dev:web or the Docker image

# Port the Express server listens on (default: 3001)
# PORT=3001

# Comma-separated list of allowed CORS origins (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Public URL of the app (used for Stripe redirect URLs)
# APP_BASE_URL=https://your-domain.com

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED for web mode.

# Secret used to sign JWTs — change this to a random 64-char string in production!
# JWT_SECRET=change-me-to-a-long-random-string

# JWT expiry (default: 7d)
# JWT_EXPIRES_IN=7d

# AES-256-GCM key for encrypting stored secrets in web mode (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SECRET_KEY=

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Required only if you want paid subscriptions.

# Stripe secret key (sk_live_... or sk_test_...)
# STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...)
# STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the Pro monthly plan
# STRIPE_PRO_PRICE_ID=


# Development & Testing Variables (Advanced)
# These are typically not needed for standard contribution.
# NODE_ENV=development
# E2E_TEST_BUILD=
# CI=
# PROTEAAI_ENGINE_URL=
# DYAD_ENGINE_URL=
# DYAD_GATEWAY_URL=