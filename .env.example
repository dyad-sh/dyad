# Environment variables needed for JoyCreate local development.
# To use, copy this file to a new file named ".env" and fill in your private keys and settings.
# Your actual .env file should NOT be committed.

# AI Provider API Keys(Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=


# Local AI Model Configuration (Optional)
# Set these if you are running local AI models like Ollama or LM Studio.
# Default for Ollama is http://127.0.0.1:11434
OLLAMA_HOST=

# PostgreSQL Database Configuration
# JoyCreate and n8n both use the same PostgreSQL database
# n8n stores its data in the "n8n" schema, JoyCreate uses the "public" schema
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=joycreate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# GitHub Integration (Optional)
# Needed for features that interact with GitHub repositories.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=

# PostHog Telemetry (Optional)
# Provide a PostHog project API key to enable anonymous telemetry.
VITE_POSTHOG_KEY=

# JoyCreate API Endpoints (Optional - defaults to production JoyCreate infra)
# Override these to self-host or develop against a local backend.
JOY_API_URL=
JOY_OAUTH_URL=
JOY_SUPABASE_OAUTH_URL=
JOY_ENGINE_URL=
JOY_HELP_URL=
JOY_DOCS_URL=
JOY_LOG_UPLOAD_URL=

# Supabase OAuth (Optional)
SUPABASE_CLIENT_ID=

# JoyMarketplace (Optional)
JOYMARKETPLACE_API_URL=
JOYMARKETPLACE_WEB_URL=
JOYMARKETPLACE_SUPABASE_URL=
JOYMARKETPLACE_SUPABASE_ANON_KEY=

# Celestia Node (Optional - for decentralized blob storage)
CELESTIA_WALLET_ADDRESS=


# Apple Notarization (macOS Build Only)
# Only required if you are building and signing a release version for macOS.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
SM_CODE_SIGNING_CERT_SHA1=


# Development & Testing Variables (Advanced)
# These are typically not needed for standard contribution.
# NODE_ENV=development
# E2E_TEST_BUILD=
# CI=
# JOY_ENGINE_URL=
# JOY_GATEWAY_URL=