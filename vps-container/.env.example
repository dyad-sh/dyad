# First security layer: protects both Dyad/noVNC and File Browser
ADMIN_USER=admin
ADMIN_PASSWORD=replace-with-a-long-admin-password

# Change this before first production deploy.
FILEBROWSER_USER=admin
FILEBROWSER_PASSWORD=replace-with-a-long-password
VNC_GEOMETRY=1440x900
VNC_DEPTH=24

# Password requested by noVNC/VNC desktop login.
VNC_PASSWORD=replace-with-a-long-vnc-password
